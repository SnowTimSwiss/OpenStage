# OpenStage Environment Variables
# Copy this file to .env and fill in your values

# Tauri Environment
# These are automatically set by Tauri at runtime
TAURI_ENV_PLATFORM=
TAURI_ENV_ARCH=
TAURI_ENV_FAMILY=
TAURI_ENV_DEBUG=

# Vite Environment
# Custom environment variables can be added here
# Must be prefixed with VITE_ to be exposed to the client
VITE_APP_VERSION=0.1.0

# Spotify Integration (optional)
# Get Client ID from https://developer.spotify.com/dashboard
# IMPORTANT: Only Client ID is needed (PKCE flow - no secret required for frontend)
VITE_SPOTIFY_CLIENT_ID=
VITE_SPOTIFY_REDIRECT_URI=http://localhost:5173
# Desktop (Tauri) auth callback server port (redirect URI becomes http://127.0.0.1:<PORT>/callback)
VITE_SPOTIFY_AUTH_PORT=8080
