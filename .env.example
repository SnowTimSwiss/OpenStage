# OpenStage Environment Variables
# Copy this file to .env and fill in your values

# Tauri Environment
# These are automatically set by Tauri at runtime
TAURI_ENV_PLATFORM=
TAURI_ENV_ARCH=
TAURI_ENV_FAMILY=
TAURI_ENV_DEBUG=

# Vite Environment
# Custom environment variables can be added here
# Must be prefixed with VITE_ to be exposed to the client
VITE_APP_VERSION=0.1.0
